#include <stdio.h>

typedef struct {
    char nome[50];
    int idade;
    float media;
} Aluno;

int main(){

   Aluno aluno1 = {"joao", 20, 8.3};
   Aluno aluno2 = {"lily", 19, 9.0};
   
   printf("Aluno: %s\nIdade: %d\nMedia: %.1f\n", aluno1.nome, aluno1.idade, aluno1.media);
   printf("\nAluno: %s\nIdade: %d\nMedia: %.1f\n", aluno2.nome, aluno2.idade, aluno2.media);
   return 0;
}
